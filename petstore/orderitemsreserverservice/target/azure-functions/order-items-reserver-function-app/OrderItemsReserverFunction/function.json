{
  "scriptFile" : "../orderitemsreserverservice-0.0.1-SNAPSHOT.jar",
  "entryPoint" : "com.chtrembl.petstore.order.items.functionapp.OrderItemsReserverFunction.run",
  "bindings" : [ {
    "type" : "httpTrigger",
    "direction" : "in",
    "name" : "req",
    "methods" : [ "POST" ],
    "authLevel" : "ANONYMOUS"
  }, {
    "type" : "blob",
    "direction" : "out",
    "name" : "outputBlob",
    "path" : "{containerName}/{sessionId}.json",
    "connection" : "AzureWebJobsStorage"
  }, {
    "type" : "http",
    "direction" : "out",
    "name" : "$return"
  } ]
}